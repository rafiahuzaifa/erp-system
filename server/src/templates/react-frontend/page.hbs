            onChange={e => handleChange('{{camelCase this.name}}', e.target.value)}
            className={`w-full border rounded-xl px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-colors ${errors.{{camelCase this.name}} ? 'border-red-400 bg-red-50' : 'border-gray-200'}`}>
            <option value="">Select {{this.name}}…</option>
{{#each this.enumValues}}
            <option value="{{this}}">{{this}}</option>
{{/each}}
          </select>
          {errors.{{camelCase this.name}} && <p className="mt-1 text-xs text-red-500 flex items-center gap-1">⚠ {errors.{{camelCase this.name}}}</p>}
        </div>
{{else}}
{{#ifEq this.type "Number"}}
{{#ifEq this.name "profit"}}
        <div>
          <label className="block text-sm font-medium text-gray-700 mb-1.5">
            Profit <span className="text-xs text-gray-400 font-normal">(auto-calculated)</span>
          </label>
          <div className={`w-full border rounded-xl px-4 py-2.5 text-sm font-bold flex items-center gap-2 ${(parseFloat(form.profit) || 0) >= 0 ? 'bg-emerald-50 border-emerald-200 text-emerald-700' : 'bg-red-50 border-red-200 text-red-600'}`}>
            <span>{(parseFloat(form.profit) || 0) >= 0 ? '▲' : '▼'}</span>
            {new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(parseFloat(form.profit) || 0)}
          </div>
          <input type="hidden" name="profit" value={form.profit || 0} />
        </div>
{{else}}
        <div>
          <label className="block text-sm font-medium text-gray-700 mb-1.5">
            {{this.name}}{{#if this.required}} <span className="text-red-400">*</span>{{/if}}
          </label>
          <div className="relative">
            {PRICE_FIELDS.has('{{camelCase this.name}}') && (
              <span className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-semibold pointer-events-none">$</span>
            )}
            <input
              type="number"
              step="any"
              value={form.{{camelCase this.name}} ?? ''}
              onChange={e => handleChange('{{camelCase this.name}}', e.target.value !== '' ? Number(e.target.value) : '')}
              placeholder="0"
              className={`w-full border rounded-xl py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-colors ${PRICE_FIELDS.has('{{camelCase this.name}}') ? 'pl-7 pr-3' : 'px-3'} ${errors.{{camelCase this.name}} ? 'border-red-400 bg-red-50' : 'border-gray-200'}`}
              {{#if this.required}}required{{/if}}
            />
          </div>
          {errors.{{camelCase this.name}} && <p className="mt-1 text-xs text-red-500 flex items-center gap-1">⚠ {errors.{{camelCase this.name}}}</p>}
        </div>
{{/ifEq}}
{{else}}
{{#ifEq this.type "Date"}}
        <div>
          <label className="block text-sm font-medium text-gray-700 mb-1.5">
            {{this.name}}{{#if this.required}} <span className="text-red-400">*</span>{{/if}}
          </label>
          <input
            type="date"
            value={form.{{camelCase this.name}} ? new Date(form.{{camelCase this.name}}).toISOString().split('T')[0] : ''}
            onChange={e => handleChange('{{camelCase this.name}}', e.target.value)}
            className={`w-full border rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-colors ${errors.{{camelCase this.name}} ? 'border-red-400 bg-red-50' : 'border-gray-200'}`}
            {{#if this.required}}required{{/if}}
          />
          {errors.{{camelCase this.name}} && <p className="mt-1 text-xs text-red-500 flex items-center gap-1">⚠ {errors.{{camelCase this.name}}}</p>}
        </div>
{{else}}
{{#ifEq this.type "Text"}}
        <div className="md:col-span-2">
          <label className="block text-sm font-medium text-gray-700 mb-1.5">
            {{this.name}}{{#if this.required}} <span className="text-red-400">*</span>{{/if}}
          </label>
          <textarea
            value={form.{{camelCase this.name}} || ''}
            onChange={e => handleChange('{{camelCase this.name}}', e.target.value)}
            rows={3}
            placeholder="Enter {{lowerCase this.name}}…"
            className={`w-full border rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent resize-none transition-colors ${errors.{{camelCase this.name}} ? 'border-red-400 bg-red-50' : 'border-gray-200'}`}
            {{#if this.required}}required{{/if}}
          />
          {errors.{{camelCase this.name}} && <p className="mt-1 text-xs text-red-500 flex items-center gap-1">⚠ {errors.{{camelCase this.name}}}</p>}
        </div>
{{else}}
        <div>
          <label className="block text-sm font-medium text-gray-700 mb-1.5">
            {{this.name}}{{#if this.required}} <span className="text-red-400">*</span>{{/if}}
          </label>
          <input
            type="text"
            value={form.{{camelCase this.name}} || ''}
            onChange={e => handleChange('{{camelCase this.name}}', e.target.value)}
            placeholder="Enter {{lowerCase this.name}}…"
            className={`w-full border rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent transition-colors ${errors.{{camelCase this.name}} ? 'border-red-400 bg-red-50' : 'border-gray-200'}`}
            {{#if this.required}}required{{/if}}
          />
          {errors.{{camelCase this.name}} && <p className="mt-1 text-xs text-red-500 flex items-center gap-1">⚠ {errors.{{camelCase this.name}}}</p>}
        </div>
{{/ifEq}}
{{/ifEq}}
{{/ifEq}}
{{/ifEq}}
{{/ifEq}}
{{/ifNotEq}}
{{/each}}
        <div className="col-span-full flex justify-end gap-3 pt-4 border-t border-gray-100 mt-2">
          <button type="button" onClick={onCancel}
            className="px-5 py-2 border border-gray-200 rounded-xl text-sm text-gray-600 hover:bg-gray-50 font-medium transition-colors">
            Cancel
          </button>
          <button type="submit" disabled={saving}
            className="px-6 py-2 bg-indigo-600 text-white rounded-xl text-sm hover:bg-indigo-700 disabled:opacity-50 font-medium shadow-sm transition-colors flex items-center gap-2">
            {saving ? <><span className="animate-spin">⟳</span> Saving…</> : item ? '✓ Update' : '+ Create'}
          </button>
        </div>
      </form>
    </div>
  );
}

{{/each}}

// ==================== Main Page ====================

export default function {{pascalCase module.name}}Page() {
  const [activeTab, setActiveTab] = useState('{{camelCase module.entities.[0].name}}');
  const { toasts, toast, dismiss } = useToast();

  const TABS = [
{{#each module.entities}}
    { id: '{{camelCase this.name}}', label: '{{pascalCase (pluralize this.name)}}' },
{{/each}}
  ];

  return (
    <div>
      <Toast toasts={toasts} onDismiss={dismiss} />

      <div className="mb-6">
        <h1 className="text-3xl font-bold text-gray-900">{{module.displayName}}</h1>
        <p className="text-gray-500 mt-1 text-sm">Manage {{lowerCase module.name}} data — add, edit, export and track records</p>
      </div>

      {/* Tab Pills */}
      <div className="flex gap-1 p-1 bg-gray-100 rounded-2xl mb-6 w-fit overflow-x-auto">
        {TABS.map(tab => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id)}
            className={`px-4 py-2 text-sm font-medium rounded-xl transition-all whitespace-nowrap ${
              activeTab === tab.id
                ? 'bg-white text-indigo-700 shadow-sm'
                : 'text-gray-500 hover:text-gray-700 hover:bg-white/50'
            }`}
          >
            {tab.label}
          </button>
        ))}
      </div>

{{#each module.entities}}
      {activeTab === '{{camelCase this.name}}' && <{{pascalCase this.name}}List toast={toast} />}
{{/each}}
    </div>
  );
}
