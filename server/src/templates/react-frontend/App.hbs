import React, { useState } from 'react';
import { BrowserRouter, Routes, Route, Link, NavLink } from 'react-router-dom';

{{#each modules}}
import {{pascalCase this.name}}Page from './pages/{{pascalCase this.name}}Page';
{{/each}}

// ===== Module Icons =====
const MODULE_ICONS = {
  inventory: '📦', sales: '🛒', purchasing: '🧾', hr: '👥',
  accounting: '💰', shipping: '🚚', fleet: '🚗', routing: '🗺️',
  procurement: '📋', suppliers: '🤝', demand: '📈', warehouse: '🏭',
};

function getIcon(name = '') {
  const lower = name.toLowerCase();
  for (const [k, icon] of Object.entries(MODULE_ICONS)) {
    if (lower.includes(k)) return icon;
  }
  return '⚙️';
}

// ===== Dashboard =====
function Dashboard() {
  const modules = [
{{#each modules}}
    {
      name: '{{this.name}}',
      displayName: '{{this.displayName}}',
      path: '/{{kebabCase this.name}}',
      entities: [{{#each this.entities}}'{{this.name}}'{{#unless @last}}, {{/unless}}{{/each}}],
    },
{{/each}}
  ];

  const colors = [
    'from-indigo-500 to-indigo-600',
    'from-emerald-500 to-emerald-600',
    'from-violet-500 to-violet-600',
    'from-amber-500 to-amber-600',
    'from-cyan-500 to-cyan-600',
    'from-rose-500 to-rose-600',
    'from-teal-500 to-teal-600',
    'from-orange-500 to-orange-600',
  ];

  return (
    <div>
      {/* Welcome Banner */}
      <div className="bg-gradient-to-r from-indigo-600 to-indigo-700 rounded-2xl p-6 mb-8 text-white shadow-lg">
        <h1 className="text-3xl font-bold">{{project.name}}</h1>
        <p className="text-indigo-200 mt-1">{{project.description}}</p>
        <div className="flex items-center gap-4 mt-4">
          <div className="bg-white/20 rounded-xl px-4 py-2 text-sm font-medium">
            {modules.length} Modules Active
          </div>
          <div className="bg-white/20 rounded-xl px-4 py-2 text-sm font-medium">
            {modules.reduce((sum, m) => sum + m.entities.length, 0)} Total Entities
          </div>
        </div>
      </div>

      {/* Module Grid */}
      <h2 className="text-lg font-bold text-gray-700 mb-4">Modules</h2>
      <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
        {modules.map((mod, idx) => (
          <Link
            key={mod.name}
            to={mod.path}
            className="group bg-white rounded-2xl border border-gray-100 overflow-hidden hover:border-indigo-200 hover:shadow-lg transition-all duration-200"
          >
            <div className={`bg-gradient-to-r ${colors[idx % colors.length]} p-4 flex items-center gap-3`}>
              <span className="text-3xl">{getIcon(mod.name)}</span>
              <div>
                <h3 className="font-bold text-white text-base leading-tight">{mod.displayName}</h3>
                <p className="text-white/70 text-xs mt-0.5">{mod.entities.length} {mod.entities.length === 1 ? 'entity' : 'entities'}</p>
              </div>
            </div>
            <div className="p-4">
              <div className="flex flex-wrap gap-1.5">
                {mod.entities.map(e => (
                  <span key={e} className="px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded-lg font-medium">{e}</span>
                ))}
              </div>
              <div className="mt-3 text-xs text-indigo-600 font-semibold group-hover:underline">
                Open module →
              </div>
            </div>
          </Link>
        ))}
      </div>
    </div>
  );
}

// ===== Sidebar =====
function Sidebar({ isOpen, onClose }) {
  const navItems = [
    { path: '/', label: 'Dashboard', icon: '📊', exact: true },
{{#each modules}}
    { path: '/{{kebabCase this.name}}', label: '{{this.displayName}}', icon: null, moduleName: '{{this.name}}', exact: false },
{{/each}}
  ];

  return (
    <>
      {isOpen && (
        <div className="fixed inset-0 bg-black/40 z-40 lg:hidden backdrop-blur-sm" onClick={onClose} />
      )}
      <aside className={`fixed top-0 left-0 z-50 h-full w-64 bg-white border-r border-gray-100 flex flex-col shadow-xl transform transition-transform duration-300 lg:translate-x-0 lg:static lg:shadow-none ${isOpen ? 'translate-x-0' : '-translate-x-full'}`}>
        {/* Logo */}
        <div className="p-5 border-b border-gray-100 bg-gradient-to-r from-indigo-600 to-indigo-700">
          <h1 className="text-lg font-bold text-white leading-tight">{{project.name}}</h1>
          <p className="text-indigo-200 text-xs mt-0.5 leading-snug">{{project.description}}</p>
        </div>

        {/* Nav */}
        <nav className="flex-1 p-3 space-y-0.5 overflow-y-auto">
          {navItems.map(item => (
            <NavLink
              key={item.path}
              to={item.path}
              end={item.exact}
              onClick={onClose}
              className={({ isActive }) =>
                `flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all ${
                  isActive
                    ? 'bg-indigo-50 text-indigo-700 shadow-sm'
                    : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900'
                }`
              }
            >
              <span className="text-base flex-shrink-0">{item.icon || getIcon(item.moduleName || '')}</span>
              <span className="truncate">{item.label}</span>
            </NavLink>
          ))}
        </nav>

        {/* Footer */}
        <div className="p-4 border-t border-gray-100 bg-gray-50">
          <p className="text-xs text-gray-400 text-center">Built with ERP Builder</p>
        </div>
      </aside>
    </>
  );
}

// ===== App Layout =====
function AppLayout() {
  const [sidebarOpen, setSidebarOpen] = useState(false);

  return (
    <div className="min-h-screen bg-gray-50 lg:flex">
      <Sidebar isOpen={sidebarOpen} onClose={() => setSidebarOpen(false)} />

      <div className="flex-1 flex flex-col min-w-0">
        {/* Header */}
        <header className="bg-white border-b border-gray-100 px-4 py-3 flex items-center justify-between lg:px-8 sticky top-0 z-30 shadow-sm">
          <button
            onClick={() => setSidebarOpen(!sidebarOpen)}
            className="lg:hidden p-2 rounded-xl hover:bg-gray-100 text-gray-600 transition-colors"
          >
            <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <div className="hidden lg:block text-sm font-semibold text-indigo-700">{{project.name}}</div>
          <div className="text-sm text-gray-400">
            {new Date().toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' })}
          </div>
        </header>

        {/* Main Content */}
        <main className="flex-1 p-4 lg:p-8 overflow-auto">
          <Routes>
            <Route path="/" element={<Dashboard />} />
{{#each modules}}
            <Route path="/{{kebabCase this.name}}/*" element={<{{pascalCase this.name}}Page />} />
{{/each}}
            <Route path="*" element={
              <div className="flex flex-col items-center justify-center py-24 text-center">
                <div className="text-7xl mb-4">🔍</div>
                <h2 className="text-2xl font-bold text-gray-700">Page not found</h2>
                <p className="text-gray-400 mt-2">The page you're looking for doesn't exist.</p>
                <Link to="/" className="mt-5 px-5 py-2.5 bg-indigo-600 text-white rounded-xl text-sm font-medium hover:bg-indigo-700 transition-colors shadow-sm">
                  ← Back to Dashboard
                </Link>
              </div>
            } />
          </Routes>
        </main>
      </div>
    </div>
  );
}

function App() {
  return (
    <BrowserRouter>
      <AppLayout />
    </BrowserRouter>
  );
}

export default App;
